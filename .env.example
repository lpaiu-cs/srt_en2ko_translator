# Copy this file to ".env" and fill in the values you want to use locally.

# Required
OPENAI_API_KEY=

# Optional: domain-specific prompt context for translation.
# Example:
# SRT_TRANSLATION_CONTEXT=These subtitles are from the Stanford CS231n lecture on computer vision and deep learning.
SRT_TRANSLATION_CONTEXT=

# Optional: tone/style guidance for the translator.
# Example:
# SRT_TRANSLATION_STYLE=Translate in a spoken, explanatory lecture style with polite Korean sentence endings.
SRT_TRANSLATION_STYLE=

# Optional: reuse the last translated sentence as context for the next request.
SRT_USE_PREVIOUS_CONTEXT=true

# Optional: JSONL glossary log for recurring terms. Shared logs help series-wide consistency.
SRT_GLOSSARY_LOG_PATH=translation_artifacts/glossary.jsonl

# Optional: max number of glossary entries injected per request.
SRT_GLOSSARY_MAX_TERMS=12

# Optional: HTTP request timeout in seconds.
SRT_REQUEST_TIMEOUT=120
