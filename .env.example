# Copy this file to ".env" and fill in the values you want to use locally.

# Required
OPENAI_API_KEY=

# Optional: default Phase1 model when --model is omitted.
SRT_PHASE1_MODEL=gpt-4.1-mini

# Backward-compatible alias for the same purpose. Leave empty if you use SRT_PHASE1_MODEL.
SRT_OPENAI_MODEL=

# Optional: default Phase2 repair model when --repair-model is omitted.
SRT_REPAIR_MODEL=gpt-4o

# Optional: domain-specific prompt context for translation.
SRT_TRANSLATION_CONTEXT=These subtitles are the Stanford CS231n lecture on computer vision and deep learning.

# Optional: tone/style guidance for the translator.
SRT_TRANSLATION_STYLE=Translate in a spoken, explanatory lecture style (like a professor talking to students). Use polite Korean sentence endings consistently (e.g. 습니다체; '~입니다', '~할 수 있습니다'), but allow occasional softer variations such as '~하는 거죠', '~라는 겁니다' to sound natural in lecture context.

# Optional: provide previous/next source sentences as context around each translation block.
SRT_USE_CONTEXT_WINDOW=true

# Optional: JSONL glossary log for recurring terms. Shared logs help series-wide consistency.
SRT_GLOSSARY_LOG_PATH=translation_artifacts/glossary.jsonl

# Optional: JSONL metrics log for per-file run statistics.
SRT_METRICS_LOG_PATH=translation_artifacts/run_metrics.jsonl

# Optional: max number of glossary entries injected per request.
SRT_GLOSSARY_MAX_TERMS=12

# Optional: HTTP request timeout in seconds.
SRT_REQUEST_TIMEOUT=120

# Optional: comma-separated English technical terms allowed to remain in output.
SRT_ALLOWED_ENGLISH_TERMS=PyTorch,NumPy,ResNet,ImageNet,Stanford,CS231n

# Optional: enable Phase2 bounded repair.
SRT_ENABLE_REPAIR=true

# Optional: retry and fallback guardrails.
SRT_PHASE1_MAX_RETRIES=2
SRT_PHASE2_MAX_REPAIRS=1
SRT_MAX_SPLIT_DEPTH=4

# Optional: dynamic translation block limits.
SRT_BLOCK_MIN_CUES=2
SRT_BLOCK_MAX_CUES=4
SRT_BLOCK_MAX_DURATION_MS=6500
SRT_BLOCK_MAX_SOURCE_CHARS=160
SRT_BLOCK_MAX_GAP_MS=800

# Optional: readability thresholds.
SRT_MAX_CHARS_PER_LINE=24
SRT_MAX_LINES_PER_CUE=2
SRT_MAX_CPS=18
